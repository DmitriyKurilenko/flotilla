# Traefik environment.
#
# install.sh prompts the operator for the ACME email during step 4 and
# writes the chosen value here, then this file is loaded by Docker
# Compose as /opt/traefik/.env when the Traefik container starts.
#
# Do NOT commit a populated /opt/traefik/.env to any repository; it
# contains the operator's contact address.

ACME_EMAIL=admin@example.com
